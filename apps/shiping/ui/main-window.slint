// Slint 1.17 的原生 Button 固定为横向图标与文字，无法表达参考设计需要的
// 圆形图标、下方标签和紧凑选中态。这个组件只补足视觉结构，点击、键盘与
// 可访问语义继续使用 Slint 原生 TouchArea、FocusScope 和 accessible-* 属性。
component CapsuleAction {
    in property <string> label;
    in property <string> accessible-name: root.label;
    in property <string> icon-path;
    in property <bool> icon-filled: false;
    in property <bool> has-menu: false;
    in property <bool> checked: false;
    in property <bool> checkable: false;
    in property <bool> danger: false;
    in property <bool> enabled: true;
    out property <bool> has-hover <=> touch-area.has-hover;

    callback clicked();

    width: 46px;
    height: 57px;
    opacity: root.enabled ? 1 : 0.38;
    forward-focus: focus-scope;
    accessible-role: button;
    accessible-label: root.accessible-name;
    accessible-enabled: root.enabled;
    accessible-checkable: root.checkable;
    accessible-checked: root.checked;
    accessible-action-default => {
        if root.enabled { root.clicked(); }
    }

    VerticalLayout {
        spacing: 4px;
        alignment: center;

        icon-background := Rectangle {
            width: 34px;
            height: 34px;
            border-radius: 17px;
            border-width: 1px;
            border-color: focus-scope.has-focus
                ? #f14f5d
                : root.danger ? #f14f5d : root.checked ? #687487 : #414957;
            background: root.danger
                ? (touch-area.has-hover ? #df4351 : #f14f5d)
                : root.checked
                    ? (touch-area.has-hover ? #3c4656 : #323a48)
                    : (touch-area.has-hover ? #303744 : #252b36);

            animate background, border-color { duration: 120ms; }

            Path {
                x: 8.5px;
                y: 8.5px;
                width: 17px;
                height: 17px;
                viewbox-width: 24;
                viewbox-height: 24;
                commands: root.icon-path;
                fill: root.icon-filled ? white : transparent;
                stroke: white;
                stroke-width: 1.5px;
                stroke-line-cap: round;
                stroke-line-join: round;
            }

            if root.has-menu: Path {
                x: 23px;
                y: 24px;
                width: 7px;
                height: 5px;
                viewbox-width: 7;
                viewbox-height: 5;
                commands: "M1 1 L3.5 3.5 L6 1";
                fill: transparent;
                stroke: #b2bac6;
                stroke-width: 1.2px;
                stroke-line-cap: round;
                stroke-line-join: round;
            }
        }

        Text {
            text: root.label;
            color: root.danger ? #ff858e : root.checked ? white : #b2bac6;
            font-size: 12px;
            font-weight: root.checked || root.danger ? 600 : 400;
            horizontal-alignment: center;
            overflow: elide;
        }
    }

    touch-area := TouchArea {
        // Keep hit-testing active while the action is disabled so the window's
        // background drag layer cannot start a move gesture over a visible control.
        clicked => { if root.enabled { root.clicked(); } }
    }

    focus-scope := FocusScope {
        x: 0px;
        width: 0px;
        enabled: root.enabled;

        key-pressed(event) => {
            if event.text == " " || event.text == "\n" {
                root.clicked();
                return accept;
            }
            return reject;
        }
    }
}

export component MainWindow inherits Window {
    title: "拾屏";
    default-font-family: "Microsoft YaHei UI";
    default-font-size: 13px;
    width: 674px;
    height: 95px;
    background: transparent;
    no-frame: true;
    always-on-top: root.recording-active;

    in-out property <int> source-mode: 0;
    in-out property <int> quality-preset: 2;
    in-out property <int> frame-rate: 0;
    in-out property <bool> system-audio: true;
    in-out property <bool> microphone: false;
    in-out property <bool> show-cursor: true;
    in-out property <bool> highlight-clicks: false;
    in-out property <int> countdown-seconds: 3;
    in-out property <string> save-directory: "视频\\ShiPing";
    in-out property <int> recording-state: 0;
    in property <string> elapsed-text: "00:00:00";
    in property <string> output-file-name: "";
    in-out property <string> status-text: "";
    in-out property <int> status-level: 0;

    private property <bool> recording-active: root.recording-state == 1 || root.recording-state == 2;
    private property <bool> recording-busy: root.recording-active || root.recording-state == 3;
    private property <string> source-label: root.source-mode == 0 ? "全屏" : root.source-mode == 1 ? "窗口" : "区域";
    private property <string> quality-label: root.quality-preset == 0
        ? "自动"
        : root.quality-preset == 1 ? "720p" : root.quality-preset == 2 ? "1080p" : "原始";
    private property <string> frame-label: root.frame-rate == 0 ? "30 FPS" : "60 FPS";
    private property <string> config-summary: root.source-label + "  ·  " + root.quality-label + "  ·  " + root.frame-label;
    private property <string> detail-text: root.recording-state == 3
        ? root.status-text
        : root.recording-state == 1
        ? "录制中  ·  " + root.config-summary
        : root.recording-state == 2
            ? "已暂停  ·  " + root.config-summary
            : root.status-text == "" ? root.config-summary : root.status-text;

    callback start-recording();
    callback pause-recording();
    callback stop-recording();
    callback begin-window-drag();
    callback show-source-menu();
    callback show-quality-menu();
    callback choose-source();
    callback choose-output-directory();
    callback open-output-directory();
    callback open-output-file();
    callback quit-application();
    callback system-audio-changed(bool);
    callback microphone-changed(bool);
    callback show-cursor-changed(bool);
    callback highlight-clicks-changed(bool);
    callback countdown-changed(int);

    Rectangle {
        x: 5px;
        y: 5px;
        width: parent.width - 10px;
        height: parent.height - 10px;
        border-radius: 17px;
        border-width: 1px;
        border-color: #495260;
        background: #1a1f29;
        drop-shadow-offset-y: 2px;
        drop-shadow-blur: 8px;
        drop-shadow-color: #00000040;

        // This layer sits behind every interactive control. It turns every remaining
        // non-interactive area into a window drag surface without stealing button input.
        TouchArea {
            mouse-cursor: move;

            pointer-event(event) => {
                if event.kind == PointerEventKind.down
                        && event.button == PointerEventButton.left
                        && !range-action.has-hover
                        && !quality-action.has-hover
                        && !fps-action.has-hover
                        && !system-audio-action.has-hover
                        && !microphone-action.has-hover
                        && !record-action.has-hover
                        && !output-touch.has-hover {
                    root.begin-window-drag();
                }
            }
        }

        HorizontalLayout {
            padding-left: 26px;
            padding-right: 2px;
            padding-top: 14px;
            padding-bottom: 14px;
            spacing: 5.5px;

            Rectangle {
                width: 60px;
                height: 57px;
                background: transparent;

                Rectangle {
                    x: 2px;
                    y: 6.5px;
                    width: 44px;
                    height: 44px;
                    border-radius: 11px;
                    border-width: 1px;
                    border-color: #414957;
                    background: #252b36;

                    Path {
                        x: 9px;
                        y: 9px;
                        width: 26px;
                        height: 26px;
                        viewbox-width: 24;
                        viewbox-height: 24;
                        commands: "M9 4 H4 V9 M15 4 H20 V9 M20 15 V20 H15 M9 20 H4 V15";
                        fill: transparent;
                        stroke: #e8ebf0;
                        stroke-width: 2px;
                        stroke-line-cap: round;
                        stroke-line-join: round;
                    }

                    Rectangle {
                        x: 18px;
                        y: 18px;
                        width: 8px;
                        height: 8px;
                        border-radius: 4px;
                        background: #f14f5d;
                    }
                }

            }

            VerticalLayout {
                width: 43px;
                height: 57px;
                spacing: 4px;
                alignment: center;

                Rectangle {
                    width: 38px;
                    height: 38px;
                    border-radius: 19px;
                    background: root.recording-state == 2 ? #e69a45 : root.recording-state == 3 ? #5d6d84 : #f14f5d;
                    drop-shadow-offset-y: 1.5px;
                    drop-shadow-blur: 6.5px;
                    drop-shadow-color: root.recording-state == 2 ? #e69a4566 : #f14f5d66;

                    Rectangle {
                        x: 14.5px;
                        y: 14.5px;
                        width: 9px;
                        height: 9px;
                        border-radius: root.recording-busy ? 2px : 4.5px;
                        background: #ffd9dd;
                    }
                }

                Text {
                    text: root.recording-state == 1 ? "REC" : root.recording-state == 2 ? "暂停" : root.recording-state == 3 ? "准备" : "就绪";
                    visible: root.recording-state != 0;
                    color: root.recording-state == 2 ? #f1b66f : #ff858e;
                    font-size: 12px;
                    font-weight: 700;
                    horizontal-alignment: center;
                }
            }

            VerticalLayout {
                width: 161px;
                height: 57px;
                spacing: 0px;

                Text {
                    height: 40px;
                    text: root.elapsed-text;
                    color: white;
                    font-size: 31px;
                    font-weight: 600;
                    letter-spacing: 0.65px;
                    vertical-alignment: center;
                }

                Rectangle {
                    height: 16px;
                    background: transparent;

                    Text {
                        width: parent.width;
                        height: parent.height;
                        text: root.detail-text;
                        color: root.status-level == 2 ? #ff858e : root.output-file-name != "" ? #9fc4ff : #8f98a7;
                        font-size: 12px;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    output-touch := TouchArea {
                        enabled: root.output-file-name != "" && root.recording-state == 0;
                        mouse-cursor: pointer;
                        clicked => { root.open-output-file(); }
                    }
                }
            }

            Rectangle {
                width: 1px;
                height: 46px;
                background: #343b47;
            }

            Rectangle {
                width: 12px;
                height: 1px;
                background: transparent;
            }

            range-action := CapsuleAction {
                label: root.recording-state == 1 ? "暂停" : root.recording-state == 2 ? "继续" : "范围";
                accessible-name: root.recording-active ? self.label : "录制范围：" + root.source-label;
                icon-path: root.recording-state == 1
                    ? "M8 6 H11 V18 H8 Z M13 6 H16 V18 H13 Z"
                    : root.recording-state == 2
                        ? "M8 5 L19 12 L8 19 Z"
                        : "M3 9 V3 H9 M15 3 H21 V9 M21 15 V21 H15 M9 21 H3 V15";
                icon-filled: root.recording-active;
                has-menu: !root.recording-active;
                checked: root.recording-state == 2 || (!root.recording-active && root.source-mode != 0);
                enabled: root.recording-state != 3;
                clicked => {
                    if root.recording-active { root.pause-recording(); }
                    else { root.show-source-menu(); }
                }
            }

            quality-action := CapsuleAction {
                label: root.quality-label;
                accessible-name: "清晰度：" + root.quality-label;
                icon-path: "M4 6 H20 M7 6 A1 1 0 1 0 9 6 A1 1 0 1 0 7 6 M4 12 H20 M14 12 A1 1 0 1 0 16 12 A1 1 0 1 0 14 12 M4 18 H20 M10 18 A1 1 0 1 0 12 18 A1 1 0 1 0 10 18";
                has-menu: true;
                enabled: !root.recording-busy;
                clicked => { root.show-quality-menu(); }
            }

            fps-action := CapsuleAction {
                label: root.frame-label;
                icon-path: "M12 3 A9 9 0 1 1 11.99 3 M12 7 V12 L16 14";
                enabled: !root.recording-busy;
                clicked => { root.frame-rate = Math.mod(root.frame-rate + 1, 2); }
            }

            system-audio-action := CapsuleAction {
                label: "系统声";
                icon-path: "M4 10 H8 L13 6 V18 L8 14 H4 Z M16 9 C18 11 18 13 16 15 M18 6 C22 10 22 14 18 18";
                checkable: true;
                checked: root.system-audio;
                clicked => {
                    root.system-audio = !root.system-audio;
                    root.system-audio-changed(root.system-audio);
                }
            }

            microphone-action := CapsuleAction {
                label: "麦克风";
                icon-path: "M9 5 A3 3 0 0 1 15 5 V12 A3 3 0 0 1 9 12 Z M6 11 A6 6 0 0 0 18 11 M12 17 V21 M8 21 H16";
                checkable: true;
                checked: root.microphone;
                clicked => {
                    root.microphone = !root.microphone;
                    root.microphone-changed(root.microphone);
                }
            }

            record-action := CapsuleAction {
                label: root.recording-busy ? "停止" : "开始";
                icon-path: root.recording-busy ? "M7 7 H17 V17 H7 Z" : "M8 5 L19 12 L8 19 Z";
                icon-filled: true;
                danger: true;
                clicked => {
                    if root.recording-busy { root.stop-recording(); }
                    else { root.start-recording(); }
                }
            }

            Rectangle {
                width: 27px;
                height: 57px;
                background: transparent;
            }
        }
    }

    context-menu := ContextMenuArea {
        width: parent.width;
        height: parent.height;

        Menu {
            MenuItem {
                title: root.recording-busy ? "停止录制" : "开始录制";
                activated => {
                    if root.recording-busy { root.stop-recording(); }
                    else { root.start-recording(); }
                }
            }
            if root.recording-active: MenuItem {
                title: root.recording-state == 2 ? "继续录制" : "暂停录制";
                activated => { root.pause-recording(); }
            }
            MenuSeparator {}
            MenuItem {
                title: "系统声音";
                checkable: true;
                checked: root.system-audio;
                activated => {
                    root.system-audio = !root.system-audio;
                    root.system-audio-changed(root.system-audio);
                }
            }
            MenuItem {
                title: "麦克风";
                checkable: true;
                checked: root.microphone;
                activated => {
                    root.microphone = !root.microphone;
                    root.microphone-changed(root.microphone);
                }
            }
            MenuSeparator {}
            MenuItem {
                title: "显示鼠标指针";
                checkable: true;
                checked: root.show-cursor;
                activated => {
                    root.show-cursor = !root.show-cursor;
                    root.show-cursor-changed(root.show-cursor);
                }
            }
            MenuItem {
                title: "突出鼠标点击";
                checkable: true;
                checked: root.highlight-clicks;
                activated => {
                    root.highlight-clicks = !root.highlight-clicks;
                    root.highlight-clicks-changed(root.highlight-clicks);
                }
            }
            Menu {
                title: "开始倒计时（" + root.countdown-seconds + " 秒）";
                enabled: !root.recording-busy;
                MenuItem { title: "不倒计时"; checkable: true; checked: root.countdown-seconds == 0; activated => { root.countdown-seconds = 0; root.countdown-changed(0); } }
                MenuItem { title: "3 秒"; checkable: true; checked: root.countdown-seconds == 3; activated => { root.countdown-seconds = 3; root.countdown-changed(3); } }
                MenuItem { title: "5 秒"; checkable: true; checked: root.countdown-seconds == 5; activated => { root.countdown-seconds = 5; root.countdown-changed(5); } }
            }
            MenuSeparator {}
            MenuItem {
                title: "打开保存目录";
                activated => { root.open-output-directory(); }
            }
            MenuItem {
                title: "更改保存目录...";
                enabled: !root.recording-busy;
                activated => { root.choose-output-directory(); }
            }
            MenuSeparator {}
            MenuItem {
                title: "退出拾屏";
                activated => { root.quit-application(); }
            }
        }
    }
}
