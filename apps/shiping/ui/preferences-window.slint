import {
    Button, ComboBox, LineEdit, Switch
} from "std-widgets.slint";
import { StatusBar } from "@shi-ui/status-bar.slint";

// Slint's LineEdit edits text but does not represent a shortcut capture session.
// This component only adds raw KeyEvent capture; focus, keyboard delivery and accessibility
// remain provided by Slint's native FocusScope and controls.
component ShortcutEditor {
    in property <string> action-label;
    in-out property <string> shortcut-text;
    in property <string> error-text;
    in property <bool> controls-enabled: true;
    in property <length> label-width: 96px;
    in property <length> row-height: 32px;

    callback captured(string, bool, bool, bool, bool);

    height: root.row-height;

    HorizontalLayout {
        spacing: 8px;
        alignment: start;
        cross-axis-alignment: center;

        Text {
            text: root.action-label;
            color: #e7eaf0;
            font-size: 13px;
            width: root.label-width;
            vertical-alignment: center;
        }

        shortcut-box := Rectangle {
            height: 32px;
            horizontal-stretch: 1;
            border-radius: 5px;
            border-width: keyboard-focus.has-focus ? 2px : 1px;
            border-color: root.error-text != ""
                ? #f06b74
                : keyboard-focus.has-focus ? #7789a6 : #4b5565;
            background: root.controls-enabled ? #252b35 : #20252d;
            opacity: root.controls-enabled ? 1 : 0.56;
            accessible-role: text-input;
            accessible-label: root.action-label + @tr("快捷键");
            accessible-value: root.shortcut-text;
            accessible-enabled: root.controls-enabled;

            Text {
                x: 11px;
                width: parent.width - 22px;
                text: keyboard-focus.has-focus
                    ? @tr("请按下快捷键，Esc 取消")
                    : root.shortcut-text == "" ? @tr("未设置") : root.shortcut-text;
                color: keyboard-focus.has-focus ? #ffffff : #c7ced9;
                vertical-alignment: center;
                overflow: elide;
            }

            TouchArea {
                enabled: root.controls-enabled;
                clicked => { keyboard-focus.focus(); }
            }

            keyboard-focus := FocusScope {
                x: 0px;
                width: 0px;
                enabled: root.controls-enabled;
                focus-on-tab-navigation: true;

                key-pressed(event) => {
                    if event.text == Key.Escape {
                        keyboard-focus.clear-focus();
                        return accept;
                    }
                    if event.text == Key.Control || event.text == Key.ControlR
                        || event.text == Key.Shift || event.text == Key.ShiftR
                        || event.text == Key.Alt || event.text == Key.AltGr
                        || event.text == Key.Meta || event.text == Key.MetaR {
                        return accept;
                    }
                    root.captured(
                        event.text,
                        event.modifiers.control,
                        event.modifiers.alt,
                        event.modifiers.shift,
                        event.modifiers.meta
                    );
                    keyboard-focus.clear-focus();
                    return accept;
                }
            }
        }

        Button {
            text: @tr("清除");
            enabled: root.controls-enabled && root.shortcut-text != "";
            clicked => {
                root.shortcut-text = "";
            }
        }
    }
}

export component PreferencesDialog inherits Dialog {
    title: @tr("拾屏首选项");
    icon: @image-url("icons/tray.svg");
    default-font-family: "Microsoft YaHei UI";
    default-font-size: 13px;
    width: 600px;
    height: 450px;
    background: #1f242c;

    in-out property <bool> recording-active: false;
    in-out property <int> language-mode: 0;
    in-out property <bool> auto-minimize-after-start: false;
    in-out property <bool> open-directory-after-stop: false;
    in-out property <int> countdown-seconds: 3;
    in-out property <string> save-directory;

    in-out property <int> quality-preset: 2;
    in-out property <int> frame-rate: 0;
    in-out property <bool> system-audio: true;
    in-out property <bool> microphone: false;
    in-out property <bool> show-cursor: true;
    in-out property <bool> highlight-clicks: false;

    in-out property <string> start-shortcut;
    in-out property <string> start-shortcut-error;
    in-out property <string> pause-shortcut;
    in-out property <string> pause-shortcut-error;
    in-out property <string> stop-shortcut;
    in-out property <string> stop-shortcut-error;
    in-out property <string> status-text;
    in-out property <bool> status-error: false;

    private property <length> setting-label-width: 96px;
    private property <length> setting-row-height: 32px;
    private property <length> setting-row-spacing: 8px;
    private property <int> current-page: 0;

    callback save-settings(bool);
    callback cancel-settings();
    callback reset-settings();
    callback preview-language(int);
    callback choose-output-directory();
    callback open-output-directory();
    callback shortcut-captured(int, string, bool, bool, bool, bool);

    VerticalLayout {
        padding: 10px;
        spacing: 6px;

        HorizontalLayout {
            spacing: 12px;
            horizontal-stretch: 1;
            vertical-stretch: 1;

            // Slint 1.17's vertical TabWidget has no public tab-row-height property.
            // Keep native button focus, keyboard and accessibility behavior while limiting
            // this navigation-only replacement to three compact rows.
            VerticalLayout {
                width: 80px;
                spacing: 4px;
                alignment: start;

                general-page-button := Button {
                    height: 36px;
                    text: @tr("常规");
                    checkable: true;
                    checked: true;
                    clicked => {
                        general-page-button.checked = true;
                        recording-page-button.checked = false;
                        shortcuts-page-button.checked = false;
                        root.current-page = 0;
                    }
                }
                recording-page-button := Button {
                    height: 36px;
                    text: @tr("录制");
                    checkable: true;
                    clicked => {
                        general-page-button.checked = false;
                        recording-page-button.checked = true;
                        shortcuts-page-button.checked = false;
                        root.current-page = 1;
                    }
                }
                shortcuts-page-button := Button {
                    height: 36px;
                    text: @tr("快捷键");
                    checkable: true;
                    clicked => {
                        general-page-button.checked = false;
                        recording-page-button.checked = false;
                        shortcuts-page-button.checked = true;
                        root.current-page = 2;
                    }
                }
            }

            Rectangle {
                width: 1px;
                background: #343b47;
            }

            Rectangle {
                horizontal-stretch: 1;
                vertical-stretch: 1;
                background: transparent;

                if root.current-page == 0: Rectangle {
                    background: transparent;

                    VerticalLayout {
                        padding: 12px;
                        spacing: root.setting-row-spacing;
                        alignment: start;

                        HorizontalLayout {
                            height: root.setting-row-height;
                            spacing: 8px;
                            alignment: start;
                            cross-axis-alignment: center;

                            Text {
                                text: @tr("界面语言");
                                color: #e7eaf0;
                                width: root.setting-label-width;
                            }
                            language-combo := ComboBox {
                                width: 180px;
                                enabled: !root.recording-active;
                                model: ["English", @tr("简体中文")];
                                current-index <=> root.language-mode;
                                selected(value) => {
                                    root.preview-language(language-combo.current-index);
                                }
                            }
                            Rectangle { horizontal-stretch: 1; }
                        }

                        Switch {
                            height: root.setting-row-height;
                            text: @tr("开始录制后自动最小化到托盘");
                            enabled: !root.recording-active;
                            checked <=> root.auto-minimize-after-start;
                        }

                        Switch {
                            height: root.setting-row-height;
                            text: @tr("停止录制并保存后打开保存目录");
                            enabled: !root.recording-active;
                            checked <=> root.open-directory-after-stop;
                        }

                        HorizontalLayout {
                            height: root.setting-row-height;
                            spacing: 8px;
                            alignment: start;
                            cross-axis-alignment: center;

                            Text {
                                text: @tr("开始倒计时");
                                color: #e7eaf0;
                                width: root.setting-label-width;
                            }
                            ComboBox {
                                width: 150px;
                                enabled: !root.recording-active;
                                model: [@tr("关闭"), @tr("3 秒"), @tr("5 秒")];
                                current-index: root.countdown-seconds == 0
                                    ? 0 : root.countdown-seconds == 3 ? 1 : 2;
                                selected(value) => {
                                    root.countdown-seconds = value == @tr("关闭")
                                        ? 0 : value == @tr("3 秒") ? 3 : 5;
                                }
                            }
                            Rectangle { horizontal-stretch: 1; }
                        }

                        HorizontalLayout {
                            height: root.setting-row-height;
                            spacing: 8px;
                            alignment: start;
                            cross-axis-alignment: center;

                            Text {
                                text: @tr("保存目录");
                                color: #e7eaf0;
                                width: root.setting-label-width;
                            }
                            LineEdit {
                                text: root.save-directory;
                                read-only: true;
                                horizontal-stretch: 1;
                            }
                            Button {
                                text: @tr("选择...");
                                enabled: !root.recording-active;
                                clicked => { root.choose-output-directory(); }
                            }
                            Button {
                                text: @tr("打开");
                                clicked => { root.open-output-directory(); }
                            }
                        }

                        Rectangle { vertical-stretch: 1; }
                    }
                }

                if root.current-page == 1: Rectangle {
                    background: transparent;

                    VerticalLayout {
                        padding: 12px;
                        spacing: root.setting-row-spacing;
                        alignment: start;

                        HorizontalLayout {
                            height: root.setting-row-height;
                            spacing: 8px;
                            alignment: start;
                            cross-axis-alignment: center;
                            Text { text: @tr("默认清晰度"); color: #e7eaf0; width: root.setting-label-width; }
                            ComboBox {
                                width: 180px;
                                enabled: !root.recording-active;
                                model: [@tr("自动"), "720p", "1080p", @tr("原始分辨率")];
                                current-index <=> root.quality-preset;
                            }
                            Rectangle { horizontal-stretch: 1; }
                        }
                        HorizontalLayout {
                            height: root.setting-row-height;
                            spacing: 8px;
                            alignment: start;
                            cross-axis-alignment: center;
                            Text { text: @tr("默认帧率"); color: #e7eaf0; width: root.setting-label-width; }
                            ComboBox {
                                width: 180px;
                                enabled: !root.recording-active;
                                model: ["30 FPS", "60 FPS"];
                                current-index <=> root.frame-rate;
                            }
                            Rectangle { horizontal-stretch: 1; }
                        }
                        Switch {
                            height: root.setting-row-height;
                            text: @tr("默认录制系统声音");
                            enabled: !root.recording-active;
                            checked <=> root.system-audio;
                        }
                        Switch {
                            height: root.setting-row-height;
                            text: @tr("默认录制麦克风");
                            enabled: !root.recording-active;
                            checked <=> root.microphone;
                        }
                        Switch {
                            height: root.setting-row-height;
                            text: @tr("显示鼠标指针");
                            enabled: !root.recording-active;
                            checked <=> root.show-cursor;
                        }
                        Switch {
                            height: root.setting-row-height;
                            text: @tr("突出鼠标点击");
                            enabled: !root.recording-active;
                            checked <=> root.highlight-clicks;
                        }

                        Rectangle { vertical-stretch: 1; }
                    }
                }

                if root.current-page == 2: Rectangle {
                    background: transparent;

                    VerticalLayout {
                        padding: 12px;
                        spacing: root.setting-row-spacing;
                        alignment: start;

                        Text {
                            text: @tr("单独使用 F1–F12，或为普通按键组合 Ctrl、Alt、Shift、Win。");
                            color: #9fa8b5;
                            font-size: 12px;
                            height: 24px;
                        }

                        ShortcutEditor {
                            action-label: @tr("开始录制");
                            label-width: root.setting-label-width;
                            row-height: root.setting-row-height;
                            controls-enabled: !root.recording-active;
                            shortcut-text <=> root.start-shortcut;
                            error-text: root.start-shortcut-error;
                            captured(text, control, alt, shift, meta) => {
                                root.shortcut-captured(0, text, control, alt, shift, meta);
                            }
                        }
                        ShortcutEditor {
                            action-label: @tr("暂停/继续");
                            label-width: root.setting-label-width;
                            row-height: root.setting-row-height;
                            controls-enabled: !root.recording-active;
                            shortcut-text <=> root.pause-shortcut;
                            error-text: root.pause-shortcut-error;
                            captured(text, control, alt, shift, meta) => {
                                root.shortcut-captured(1, text, control, alt, shift, meta);
                            }
                        }
                        ShortcutEditor {
                            action-label: @tr("停止录制");
                            label-width: root.setting-label-width;
                            row-height: root.setting-row-height;
                            controls-enabled: !root.recording-active;
                            shortcut-text <=> root.stop-shortcut;
                            error-text: root.stop-shortcut-error;
                            captured(text, control, alt, shift, meta) => {
                                root.shortcut-captured(2, text, control, alt, shift, meta);
                            }
                        }

                        Rectangle { vertical-stretch: 1; }
                    }
                }
            }
        }

        StatusBar {
            status-text: root.status-text != ""
                ? root.status-text
                : root.recording-active
                    ? @tr("录制进行中：停止录制后才能应用修改")
                    : @tr("修改后请单击“应用”或“确定”保存");
            status-level: root.status-error ? 2 : 0;
        }
    }

    Button {
        text: @tr("恢复默认");
        enabled: !root.recording-active;
        dialog-button-role: reset;
        clicked => { root.reset-settings(); }
    }
    Button {
        text: @tr("取消");
        dialog-button-role: reject;
        clicked => { root.cancel-settings(); }
    }
    Button {
        text: @tr("应用");
        enabled: !root.recording-active;
        dialog-button-role: apply;
        clicked => { root.save-settings(false); }
    }
    Button {
        text: @tr("确定");
        enabled: !root.recording-active;
        dialog-button-role: accept;
        clicked => { root.save-settings(true); }
    }
}
