import { AnnotationView } from "annotation-view.slint";

export component PinWindow inherits Window {
    title: @tr("钉住图像");
    preferred-width: 360px;
    preferred-height: 240px;
    background: #000000;
    no-frame: true;
    always-on-top: true;

    in property <image> screenshot;
    in-out property <int> alpha-percent: 100;
    in-out property <bool> shadow-enabled: true;
    in-out property <bool> top-enabled: true;
    in property <bool> wheel-zoom: true;
    in property <int> zoom-step: 15;
    in property <bool> double-click-close: true;
    in-out property <int> scale-percent: 100;
    in property <string> original-size-text;
    in property <bool> has-source-file: false;
    in property <bool> ocr-available: false;
    in-out property <bool> toolbar-visible: false;
    in property <[AnnotationView]> annotations;
    in-out property <int> active-tool: 0;
    in-out property <int> color-index: 0;
    in-out property <int> stroke-radius: 2;
    in-out property <bool> drawing: false;
    in-out property <bool> text-editing: false;
    in-out property <float> text-editor-x: 0;
    in-out property <float> text-editor-y: 0;
    in-out property <string> text-editor-value;
    property <float> annotation-brush-radius: root.active-tool == 6
        ? (root.stroke-radius == 1 ? 10 : root.stroke-radius == 4 ? 30 : 18)
        : 10;

    callback close-pin();
    callback drag-pin();
    callback scale-pin(int);
    callback set-toolbar(bool);
    callback set-scale(int);
    callback fit-screen();
    callback copy-image();
    callback save-image();
    callback recognize-text();
    callback ocr-result(int, string);
    callback set-opacity(int);
    callback set-shadow(bool);
    callback set-top(bool);
    callback replace-clipboard();
    callback replace-file();
    callback reveal-file();
    callback rotate-left();
    callback rotate-right();
    callback flip-horizontal();
    callback flip-vertical();
    callback begin-annotation(float, float, int);
    callback update-annotation(float, float);
    callback finish-annotation();
    callback add-text(float, float, string, int);
    callback undo();
    callback redo();

    public function commit-text-editor() {
        if root.text-editing && root.text-editor-value != "" {
            let image-x = root.text-editor-x / (root.width / 1px) * root.screenshot.width;
            let image-y = root.text-editor-y / (root.height / 1px) * root.screenshot.height;
            let font-size = root.stroke-radius == 1 ? 16 : root.stroke-radius == 4 ? 28 : 20;
            root.add-text(image-x, image-y, root.text-editor-value, font-size);
        }
        root.text-editor-value = "";
        root.text-editing = false;
    }

    FocusScope {
        key-pressed(event) => {
            if event.text == Key.Escape {
                root.close-pin();
                accept
            } else {
                reject
            }
        }
    }

    menu-area := ContextMenuArea {
        Menu {
            MenuItem {
                title: @tr("复制图像");
                activated => { root.copy-image(); }
            }
            MenuItem {
                title: @tr("图像另存为...");
                activated => { root.save-image(); }
            }
            if root.ocr-available: MenuItem {
                title: @tr("OCR 识别");
                activated => { root.recognize-text(); }
            }
            MenuSeparator {}
            MenuItem {
                title: @tr("显示工具栏");
                checkable: true;
                checked: root.toolbar-visible;
                activated => { root.set-toolbar(!root.toolbar-visible); }
            }
            MenuItem {
                title: @tr("窗口阴影");
                checkable: true;
                checked: root.shadow-enabled;
                activated => { root.set-shadow(!root.shadow-enabled); }
            }
            MenuItem {
                title: @tr("始终置顶");
                checkable: true;
                checked: root.top-enabled;
                activated => { root.set-top(!root.top-enabled); }
            }
            Menu {
                title: @tr("不透明度");
                MenuItem { title: "25%"; checkable: true; checked: root.alpha-percent == 25; activated => { root.set-opacity(25); } }
                MenuItem { title: "50%"; checkable: true; checked: root.alpha-percent == 50; activated => { root.set-opacity(50); } }
                MenuItem { title: "75%"; checkable: true; checked: root.alpha-percent == 75; activated => { root.set-opacity(75); } }
                MenuItem { title: "90%"; checkable: true; checked: root.alpha-percent == 90; activated => { root.set-opacity(90); } }
                MenuItem { title: "100%"; checkable: true; checked: root.alpha-percent == 100; activated => { root.set-opacity(100); } }
            }
            Menu {
                title: @tr("缩放（{}%）", root.scale-percent);
                MenuItem { title: "25%"; checkable: true; checked: root.scale-percent == 25; activated => { root.set-scale(25); } }
                MenuItem { title: "50%"; checkable: true; checked: root.scale-percent == 50; activated => { root.set-scale(50); } }
                MenuItem { title: "75%"; checkable: true; checked: root.scale-percent == 75; activated => { root.set-scale(75); } }
                MenuItem { title: "100%"; checkable: true; checked: root.scale-percent == 100; activated => { root.set-scale(100); } }
                MenuItem { title: "125%"; checkable: true; checked: root.scale-percent == 125; activated => { root.set-scale(125); } }
                MenuItem { title: "150%"; checkable: true; checked: root.scale-percent == 150; activated => { root.set-scale(150); } }
                MenuItem { title: "200%"; checkable: true; checked: root.scale-percent == 200; activated => { root.set-scale(200); } }
                MenuSeparator {}
                MenuItem { title: @tr("适合屏幕"); activated => { root.fit-screen(); } }
                MenuItem { title: @tr("恢复原始大小"); activated => { root.set-scale(100); } }
            }
            MenuSeparator {}
            Menu {
                title: @tr("图像处理");
                MenuItem { title: @tr("向左旋转 90°"); activated => { root.rotate-left(); } }
                MenuItem { title: @tr("向右旋转 90°"); activated => { root.rotate-right(); } }
                MenuItem { title: @tr("水平翻转"); activated => { root.flip-horizontal(); } }
                MenuItem { title: @tr("垂直翻转"); activated => { root.flip-vertical(); } }
            }
            Menu {
                title: @tr("替换图像");
                MenuItem { title: @tr("从剪贴板"); activated => { root.replace-clipboard(); } }
                MenuItem { title: @tr("从文件..."); activated => { root.replace-file(); } }
            }
            if root.has-source-file: MenuItem {
                title: @tr("在文件夹中显示");
                activated => { root.reveal-file(); }
            }
            MenuSeparator {}
            MenuItem { title: @tr("关闭"); activated => { root.close-pin(); } }
            MenuItem { title: @tr("原始尺寸：{}", root.original-size-text); enabled: false; }
        }

        Image {
        width: parent.width;
        height: parent.height;
        source: root.screenshot;
        image-fit: fill;
        }

    TouchArea {
        width: parent.width;
        height: parent.height;
        enabled: root.active-tool == 0;
        mouse-cursor: move;

        pointer-event(event) => {
            if event.kind == PointerEventKind.down {
                if event.button == PointerEventButton.left {
                    root.drag-pin();
                } else if event.button == PointerEventButton.right {
                    menu-area.show({ x: self.mouse-x, y: self.mouse-y });
                }
            }
        }

        double-clicked => {
            if root.double-click-close {
                root.close-pin();
            }
        }

        scroll-event(event) => {
            if root.wheel-zoom {
                if event.delta-y < 0 {
                    root.scale-pin(1);
                } else if event.delta-y > 0 {
                    root.scale-pin(-1);
                }
            }
            accept
        }
    }

    for annotation in root.annotations: Path {
        visible: annotation.kind == 0;
        width: parent.width;
        height: parent.height;
        commands: annotation.commands;
        viewbox-width: root.screenshot.width;
        viewbox-height: root.screenshot.height;
        fit: fill;
        clip: true;
        fill: transparent;
        stroke: annotation.stroke-color;
        stroke-width: Math.max(
            1,
            annotation.stroke-width * parent.width / 1px / root.screenshot.width
        ) * 1px;
        stroke-line-cap: round;
    }

    for annotation in root.annotations: Text {
        visible: annotation.kind == 1;
        x: annotation.x / root.screenshot.width * parent.width;
        y: annotation.y / root.screenshot.height * parent.height;
        text: annotation.text;
        color: annotation.stroke-color;
        font-family: "Microsoft YaHei UI";
        font-size: Math.max(
            1px,
            annotation.font-size * parent.width / 1px / root.screenshot.width * 1px
        );
    }

    annotation-touch := TouchArea {
        visible: root.active-tool > 0;
        width: parent.width;
        height: parent.height;
        mouse-cursor: root.active-tool == 5 || root.active-tool == 6 ? none : crosshair;

        pointer-event(event) => {
            let image-x = self.mouse-x / self.width * root.screenshot.width;
            let image-y = self.mouse-y / self.height * root.screenshot.height;
            if event.kind == PointerEventKind.down {
                if event.button == PointerEventButton.left {
                    if root.active-tool == 4 {
                        root.commit-text-editor();
                        root.text-editor-x = self.mouse-x / 1px;
                        root.text-editor-y = self.mouse-y / 1px;
                        root.text-editor-value = "";
                        root.text-editing = true;
                        text-editor.focus();
                    } else {
                        root.drawing = true;
                        root.begin-annotation(image-x, image-y, root.active-tool);
                    }
                } else if event.button == PointerEventButton.right {
                    menu-area.show({ x: self.mouse-x, y: self.mouse-y });
                }
            } else if event.kind == PointerEventKind.move && root.drawing {
                root.update-annotation(image-x, image-y);
            } else if event.kind == PointerEventKind.up && root.drawing {
                root.update-annotation(image-x, image-y);
                root.finish-annotation();
                root.drawing = false;
            } else if event.kind == PointerEventKind.cancel && root.drawing {
                root.finish-annotation();
                root.drawing = false;
            }
        }
    }

    if (root.active-tool == 5 || root.active-tool == 6) && annotation-touch.has-hover: Rectangle {
        property <length> brush-diameter: Math.max(
            10px,
            root.annotation-brush-radius * 2 * parent.width / Math.max(1, root.screenshot.width)
        );
        x: annotation-touch.mouse-x - self.width / 2;
        y: annotation-touch.mouse-y - self.height / 2;
        width: self.brush-diameter;
        height: self.brush-diameter;
        border-radius: self.width / 2;
        border-width: 2px;
        border-color: root.active-tool == 6 ? #54a5ff : #ffffff;
        background: root.active-tool == 6 ? #54a5ff22 : #ffffff22;

        Rectangle {
            x: 1px;
            y: 1px;
            width: Math.max(0px, parent.width - 2px);
            height: Math.max(0px, parent.height - 2px);
            border-radius: self.width / 2;
            border-width: 1px;
            border-color: #20242bcc;
            background: transparent;
        }
    }

    text-editor-frame := Rectangle {
        visible: root.text-editing;
        x: root.text-editor-x * 1px;
        y: root.text-editor-y * 1px;
        width: Math.max(80px, Math.min(240px, parent.width - self.x));
        height: 30px;
        border-width: 1px;
        border-color: #54a5ff;
        background: #ffffffee;

        text-editor := TextInput {
            x: 4px;
            y: 2px;
            width: parent.width - 8px;
            height: parent.height - 4px;
            text <=> root.text-editor-value;
            color: root.color-index == 0 ? #ec5c66
                : root.color-index == 1 ? #4a90e2
                : root.color-index == 2 ? #31a36b : #c59b00;
            font-family: "Microsoft YaHei UI";
            font-size: root.stroke-radius == 1 ? 16px
                : root.stroke-radius == 4 ? 28px : 20px;
            single-line: true;
            accepted => { root.commit-text-editor(); }
            key-pressed(event) => {
                if event.text == Key.Escape {
                    root.text-editor-value = "";
                    root.text-editing = false;
                    accept
                } else {
                    reject
                }
            }
        }
    }

    Rectangle {
        width: parent.width;
        height: parent.height;
        border-width: 1px;
        border-color: #54a5ff;
        background: transparent;
    }
    }

}
