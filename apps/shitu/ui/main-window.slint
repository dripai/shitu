import { Palette } from "std-widgets.slint";
import { SettingsPanel } from "settings-panel.slint";
import { StatusBar } from "@shi-ui/status-bar.slint";

export component MainWindow inherits Window {
    title: @tr("拾图");
    icon: @image-url("icons/tray.svg");
    // Fluent body text is 1.0769rem; this resolves native controls to 13px.
    default-font-size: 12.07px;
    preferred-width: 468px;
    preferred-height: 475px;
    min-width: 448px;
    min-height: 445px;
    max-width: 620px;
    background: Palette.background;

    in property <string> status-text: @tr("就绪");
    in property <int> status-level: 0;
    in property <bool> ocr-available: false;
    in property <string> ocr-status;
    in property <bool> system-ocr-available: false;
    in property <string> system-ocr-status;
    in property <bool> ai-ocr-available: false;
    in property <string> ai-ocr-status;
    in property <bool> ai-ocr-can-install: false;

    in-out property <int> current-tab: 0;
    in-out property <int> theme-mode: 0;
    in-out property <int> language-mode: 0;
    in-out property <bool> launch-at-startup: false;
    in-out property <int> image-format: 0;
    in-out property <int> jpeg-quality: 90;
    in-out property <string> save-directory;
    in-out property <string> filename-template;
    in-out property <bool> auto-save: false;
    in-out property <bool> save-notification: true;
    in-out property <int> ocr-engine: 0;
    in-out property <int> ocr-minimum-confidence: 60;
    in-out property <int> pin-opacity: 100;
    in-out property <bool> pin-shadow: true;
    in-out property <bool> pin-always-on-top: true;
    in-out property <bool> pin-wheel-zoom: true;
    in-out property <int> pin-zoom-step: 15;
    in-out property <bool> pin-double-click-close: true;
    in-out property <string> hotkey-text;
    in property <int> hotkey-status: 0;
    in property <string> hotkey-status-tip;
    in property <string> version-text;
    in property <string> build-text;
    in property <string> log-path;
    in property <string> config-path;

    callback capture();
    callback apply-settings();
    callback restore-defaults(int);
    callback choose-save-directory();
    callback open-save-directory();
    callback open-log-directory();
    callback open-config-directory();
    callback config-hint(bool);
    callback clear-hotkey();
    callback prepare-ai-ocr();
    callback preview-language(int);
    callback ai-ocr-prepared(string);

    init => {
        Palette.color-scheme = root.theme-mode == 1
            ? ColorScheme.light
            : root.theme-mode == 2 ? ColorScheme.dark : ColorScheme.unknown;
    }
    changed theme-mode => {
        Palette.color-scheme = root.theme-mode == 1
            ? ColorScheme.light
            : root.theme-mode == 2 ? ColorScheme.dark : ColorScheme.unknown;
    }

    VerticalLayout {
        spacing: 0px;

        Rectangle {
            background: Palette.background;

            VerticalLayout {
                padding-left: 8px;
                padding-right: 8px;
                padding-bottom: 8px;
                padding-top: 0px;

                SettingsPanel {
                    current-tab <=> root.current-tab;
                    theme-mode <=> root.theme-mode;
                    language-mode <=> root.language-mode;
                    launch-at-startup <=> root.launch-at-startup;
                    image-format <=> root.image-format;
                    jpeg-quality <=> root.jpeg-quality;
                    save-directory <=> root.save-directory;
                    filename-template <=> root.filename-template;
                    auto-save <=> root.auto-save;
                    save-notification <=> root.save-notification;
                    ocr-engine <=> root.ocr-engine;
                    ocr-minimum-confidence <=> root.ocr-minimum-confidence;
                    pin-opacity <=> root.pin-opacity;
                    pin-shadow <=> root.pin-shadow;
                    pin-always-on-top <=> root.pin-always-on-top;
                    pin-wheel-zoom <=> root.pin-wheel-zoom;
                    pin-zoom-step <=> root.pin-zoom-step;
                    pin-double-click-close <=> root.pin-double-click-close;
                    hotkey-text <=> root.hotkey-text;
                    hotkey-status: root.hotkey-status;
                    hotkey-status-tip: root.hotkey-status-tip;
                    version-text: root.version-text;
                    build-text: root.build-text;
                    log-path: root.log-path;
                    config-path: root.config-path;
                    ocr-available: root.ocr-available;
                    ocr-status: root.ocr-status;
                    system-ocr-available: root.system-ocr-available;
                    system-ocr-status: root.system-ocr-status;
                    ai-ocr-available: root.ai-ocr-available;
                    ai-ocr-status: root.ai-ocr-status;
                    ai-ocr-can-install: root.ai-ocr-can-install;

                    capture => { root.capture(); }
                    apply-settings => { root.apply-settings(); }
                    restore-defaults(tab) => { root.restore-defaults(tab); }
                    choose-save-directory => { root.choose-save-directory(); }
                    open-save-directory => { root.open-save-directory(); }
                    open-log-directory => { root.open-log-directory(); }
                    open-config-directory => { root.open-config-directory(); }
                    config-hint(visible) => { root.config-hint(visible); }
                    clear-hotkey => { root.clear-hotkey(); }
                    prepare-ai-ocr => { root.prepare-ai-ocr(); }
                    preview-language(mode) => { root.preview-language(mode); }
                }
            }
        }

        StatusBar {
            status-text: root.status-text;
            status-level: root.status-level;
        }
    }
}
