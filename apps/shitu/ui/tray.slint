export component CaptureTray inherits SystemTrayIcon {
    icon: @image-url("icons/tray.svg");
    tooltip: @tr("拾图");
    title: @tr("拾图");

    callback capture();
    callback show-main();
    callback hide-main();
    callback quit();

    clicked => { root.show-main(); }

    Menu {
        MenuItem {
            title: @tr("区域截图");
            activated => { root.capture(); }
        }
        MenuSeparator { }
        MenuItem {
            title: @tr("显示控制面板");
            activated => { root.show-main(); }
        }
        MenuItem {
            title: @tr("隐藏控制面板");
            activated => { root.hide-main(); }
        }
        MenuSeparator { }
        MenuItem {
            title: @tr("退出");
            activated => { root.quit(); }
        }
    }
}
