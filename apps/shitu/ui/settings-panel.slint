import {
    Button, CheckBox, ComboBox, LineEdit, Palette, SpinBox, TabWidget
} from "std-widgets.slint";

global SettingsTypography {
    out property <length> title-font-size: 14px;
    out property <length> body-font-size: 13px;
}

component FieldLabel inherits Text {
    width: 92px;
    color: Palette.foreground;
    font-size: SettingsTypography.body-font-size;
    vertical-alignment: center;
}

component SectionTitle inherits Text {
    height: 24px;
    color: Palette.foreground;
    font-size: SettingsTypography.title-font-size;
    font-weight: 700;
    vertical-alignment: center;
}

component CenteredTabLabel inherits Rectangle {
    in property <string> text;
    in property <bool> selected;

    height: 32px;
    horizontal-stretch: 1;

    Text {
        width: 100%;
        height: 100%;
        text: root.text;
        color: root.selected ? Palette.foreground : Palette.alternate-foreground;
        font-size: SettingsTypography.body-font-size;
        font-weight: root.selected ? 700 : 400;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component AboutLinkRow inherits HorizontalLayout {
    in property <string> label;
    in property <string> link-text;
    in property <string> target-url;

    height: 28px;
    spacing: 0px;

    Text {
        width: 72px;
        text: root.label;
        color: Palette.alternate-foreground;
        font-size: SettingsTypography.body-font-size;
        vertical-alignment: center;
    }
    Button {
        text: root.link-text;
        horizontal-stretch: 1;
        clicked => { Platform.open-url(root.target-url); }
    }
}

component PathActionButton inherits Rectangle {
    in property <string> text;
    callback activated();
    callback hover-changed(bool);

    width: 92px;
    height: 28px;
    border-width: 1px;
    border-color: Palette.foreground.with-alpha(0.24);
    border-radius: 3px;
    background: touch.pressed
        ? Palette.selection-background
        : touch.has-hover ? Palette.alternate-background : Palette.background;
    accessible-role: button;
    accessible-label: root.text;
    accessible-action-default => { root.activated(); }

    Text {
        text: root.text;
        color: Palette.foreground;
        font-size: SettingsTypography.body-font-size;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.activated(); }
        changed has-hover => { root.hover-changed(self.has-hover); }
    }
}

export component SettingsPanel inherits Rectangle {
    background: Palette.background;

    in-out property <int> current-tab: 0;
    in-out property <int> theme-mode: 0;
    in-out property <int> language-mode: 0;
    in-out property <bool> launch-at-startup: false;
    in-out property <bool> start-minimized: false;
    in-out property <int> image-format: 0;
    in-out property <int> jpeg-quality: 90;
    in-out property <string> save-directory;
    in-out property <string> filename-template;
    in-out property <bool> auto-save: false;
    in-out property <bool> save-notification: true;
    in-out property <int> pin-opacity: 100;
    in-out property <bool> pin-shadow: true;
    in-out property <bool> pin-always-on-top: true;
    in-out property <bool> pin-wheel-zoom: true;
    in-out property <int> pin-zoom-step: 15;
    in-out property <bool> pin-double-click-close: true;
    in-out property <string> hotkey-text;
    in property <int> hotkey-status: 0;
    in property <string> hotkey-status-tip;
    in property <string> version-text;
    in property <string> build-text;
    in property <string> log-path;
    in property <string> config-path;
    in property <bool> ocr-available: false;
    in property <string> ocr-status;
    in property <bool> system-ocr-available: false;
    in property <string> system-ocr-status;
    in property <bool> ai-ocr-available: false;
    in property <string> ai-ocr-status;
    in property <bool> ai-ocr-can-install: false;
    in-out property <int> ocr-engine: 0;
    in-out property <int> ocr-minimum-confidence: 60;

    callback apply-settings();
    callback capture();
    callback restore-defaults(int);
    callback choose-save-directory();
    callback open-save-directory();
    callback open-log-directory();
    callback open-config-directory();
    callback config-hint(bool);
    callback clear-hotkey();
    callback prepare-ai-ocr();
    callback preview-language(int);

    changed current-tab => { root.config-hint(false); }
    changed language-mode => { root.preview-language(root.language-mode); }

    VerticalLayout {
        padding-left: 10px;
        padding-right: 10px;
        padding-bottom: 10px;
        padding-top: 0px;
        spacing: 0px;

        Rectangle {
            vertical-stretch: 1;

            tabs := TabWidget {
                width: 100%;
                height: 100%;
                current-index <=> root.current-tab;

            Tab {
                title: "";
                horizontal-stretch: 1;
                VerticalLayout {
                padding: 12px;
                spacing: 8px;
                SectionTitle { text: @tr("应用"); }
                HorizontalLayout {
                    spacing: 16px;
                    CheckBox {
                        text: @tr("开机启动");
                        checked <=> root.launch-at-startup;
                    }
                    CheckBox {
                        text: @tr("启动最小化");
                        enabled: root.launch-at-startup;
                        checked <=> root.start-minimized;
                    }
                }
                HorizontalLayout {
                    height: 26px;
                    FieldLabel { text: @tr("外观模式"); }
                    ComboBox {
                        model: [@tr("跟随系统"), @tr("浅色"), @tr("深色")];
                        current-index <=> root.theme-mode;
                    }
                }
                HorizontalLayout {
                    height: 26px;
                    FieldLabel { text: @tr("界面语言"); }
                    ComboBox {
                        model: [@tr("跟随系统"), @tr("简体中文"), "English"];
                        current-index <=> root.language-mode;
                    }
                }
                Rectangle { height: 1px; background: Palette.foreground.with-alpha(0.16); }
                SectionTitle { text: @tr("文件与诊断"); }
                HorizontalLayout {
                    height: 28px;
                    spacing: 8px;
                    PathActionButton {
                        text: @tr("打开日志");
                        activated => { root.open-log-directory(); }
                    }
                    Text {
                        text: root.log-path;
                        color: Palette.alternate-foreground;
                        font-size: SettingsTypography.body-font-size;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }
                HorizontalLayout {
                    height: 28px;
                    spacing: 8px;
                    PathActionButton {
                        text: @tr("打开配置");
                        activated => { root.open-config-directory(); }
                        hover-changed(hovered) => { root.config-hint(hovered); }
                    }
                    Text {
                        text: root.config-path;
                        color: Palette.alternate-foreground;
                        font-size: SettingsTypography.body-font-size;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }
                Rectangle { }
                }
            }

            Tab {
                title: "";
                horizontal-stretch: 1;
                VerticalLayout {
                padding: 12px;
                spacing: 7px;
                VerticalLayout {
                    spacing: 7px;
                    SectionTitle { text: @tr("输出"); }
                    HorizontalLayout {
                        height: 26px;
                        FieldLabel { text: @tr("图像格式"); }
                        ComboBox {
                            width: 112px;
                            model: ["PNG", "JPEG"];
                            current-index <=> root.image-format;
                        }
                        Text {
                            width: 68px;
                            text: @tr("JPEG 质量");
                            color: Palette.foreground;
                            font-size: SettingsTypography.body-font-size;
                            vertical-alignment: center;
                        }
                        SpinBox {
                            width: 72px;
                            enabled: root.image-format == 1;
                            value <=> root.jpeg-quality;
                            minimum: 1;
                            maximum: 100;
                        }
                    }
                    HorizontalLayout {
                        height: 26px;
                        spacing: 6px;
                        FieldLabel { text: @tr("保存目录"); }
                        LineEdit {
                            text <=> root.save-directory;
                        }
                        Button {
                            width: 58px;
                            text: @tr("选择...");
                            clicked => { root.choose-save-directory(); }
                        }
                        Button {
                            width: 72px;
                            text: @tr("打开目录");
                            clicked => { root.open-save-directory(); }
                        }
                    }
                    HorizontalLayout {
                        height: 26px;
                        FieldLabel { text: @tr("文件名模板"); }
                        LineEdit {
                            text <=> root.filename-template;
                        }
                    }
                    CheckBox {
                        text: @tr("自动保存（执行复制或钉住时同时保存）");
                        checked <=> root.auto-save;
                    }
                    CheckBox {
                        text: @tr("显示保存结果");
                        checked <=> root.save-notification;
                    }
                    Rectangle { }
                }
                }
            }

            Tab {
                title: "";
                horizontal-stretch: 1;
                VerticalLayout {
                padding: 12px;
                spacing: 8px;
                SectionTitle { text: @tr("识别引擎"); }
                HorizontalLayout {
                    height: 26px;
                    FieldLabel { text: @tr("默认引擎"); }
                    ComboBox {
                        width: 220px;
                        model: [@tr("兼容系统 OCR"), @tr("Windows AI OCR（增强）")];
                        current-index <=> root.ocr-engine;
                    }
                    Rectangle { }
                }
                HorizontalLayout {
                    height: 26px;
                    FieldLabel { text: @tr("兼容 OCR"); }
                    Text {
                        text: root.system-ocr-status;
                        color: root.system-ocr-available ? #16833d : #cf222e;
                        font-size: SettingsTypography.body-font-size;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }
                HorizontalLayout {
                    height: 26px;
                    FieldLabel { text: @tr("增强 OCR"); }
                    Text {
                        text: root.ai-ocr-status;
                        color: root.ai-ocr-available ? #16833d : #cf222e;
                        font-size: SettingsTypography.body-font-size;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                    if root.ai-ocr-can-install: Button {
                        width: 78px;
                        text: @tr("安装模型");
                        clicked => { root.prepare-ai-ocr(); }
                    }
                }
                Rectangle { height: 1px; background: Palette.foreground.with-alpha(0.16); }
                SectionTitle { text: @tr("增强 OCR 输出"); }
                HorizontalLayout {
                    height: 26px;
                    FieldLabel { text: @tr("最低置信度"); }
                    SpinBox {
                        width: 84px;
                        enabled: root.ocr-engine == 1 && root.ai-ocr-available;
                        value <=> root.ocr-minimum-confidence;
                        minimum: 0;
                        maximum: 100;
                    }
                    Text {
                        text: "%";
                        color: Palette.foreground;
                        font-size: SettingsTypography.body-font-size;
                        vertical-alignment: center;
                    }
                    Rectangle { }
                }
                Text {
                    text: @tr("仅过滤 Windows AI OCR 返回的低置信度词语。");
                    color: Palette.alternate-foreground;
                    font-size: SettingsTypography.body-font-size;
                }
                Rectangle { }
                }
            }

            Tab {
                title: "";
                horizontal-stretch: 1;
                VerticalLayout {
                padding: 12px;
                spacing: 8px;
                SectionTitle { text: @tr("新建钉住窗口"); }
                HorizontalLayout {
                    height: 26px;
                    FieldLabel { text: @tr("默认不透明度"); }
                    SpinBox {
                        value <=> root.pin-opacity;
                        minimum: 25;
                        maximum: 100;
                    }
                    Text {
                        text: "%";
                        color: Palette.foreground;
                        font-size: SettingsTypography.body-font-size;
                        vertical-alignment: center;
                    }
                }
                CheckBox { text: @tr("窗口阴影"); checked <=> root.pin-shadow; }
                CheckBox { text: @tr("始终置顶"); checked <=> root.pin-always-on-top; }
                CheckBox { text: @tr("启用滚轮缩放"); checked <=> root.pin-wheel-zoom; }
                HorizontalLayout {
                    height: 26px;
                    FieldLabel { text: @tr("缩放步长"); }
                    SpinBox {
                        enabled: root.pin-wheel-zoom;
                        value <=> root.pin-zoom-step;
                        minimum: 5;
                        maximum: 100;
                    }
                    Text {
                        text: "%";
                        color: Palette.foreground;
                        font-size: SettingsTypography.body-font-size;
                        vertical-alignment: center;
                    }
                }
                CheckBox { text: @tr("双击关闭"); checked <=> root.pin-double-click-close; }
                Rectangle { }
                }
            }

            Tab {
                title: "";
                horizontal-stretch: 1;
                VerticalLayout {
                padding: 12px;
                spacing: 8px;
                SectionTitle { text: @tr("全局快捷键"); }
                HorizontalLayout {
                    height: 28px;
                    spacing: 6px;
                    FieldLabel { text: @tr("区域截图"); }
                    LineEdit {
                        width: 190px;
                        text <=> root.hotkey-text;
                        placeholder-text: @tr("默认 Ctrl+Alt+C；留空则关闭");
                    }
                    Button {
                        width: 52px;
                        text: @tr("清除");
                        clicked => { root.clear-hotkey(); }
                    }
                    if root.hotkey-status > 0: Rectangle {
                        width: 22px;
                        height: 22px;
                        border-radius: 11px;
                        background: root.hotkey-status == 1 ? #238636 : #cf222e;
                        Text {
                            text: root.hotkey-status == 1 ? "√" : "!";
                            color: #ffffff;
                            font-size: 15px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        Tooltip { text: @markdown("\{root.hotkey-status-tip}"); }
                    }
                    Rectangle { }
                }
                if root.hotkey-status != 1: Text {
                    text: root.hotkey-status == 0
                        ? @tr("未设置时不会注册任何全局快捷键。")
                        : root.hotkey-status-tip;
                    color: Palette.alternate-foreground;
                    font-size: SettingsTypography.body-font-size;
                }
                Rectangle { }
                }
            }

            Tab {
                title: "";
                horizontal-stretch: 1;
                VerticalLayout {
                padding: 12px;
                spacing: 6px;
                HorizontalLayout {
                    height: 44px;
                    spacing: 14px;
                    HorizontalLayout {
                        height: 100%;
                        spacing: 7px;
                        Image {
                            width: 32px;
                            height: 32px;
                            source: @image-url("icons/tray.svg");
                            image-fit: contain;
                        }
                        Text {
                            height: 32px;
                            text: @tr("拾图");
                            color: Palette.foreground;
                            font-size: 16px;
                            font-weight: 700;
                            vertical-alignment: center;
                        }
                    }
                    VerticalLayout {
                        height: 40px;
                        spacing: 2px;
                        Text {
                            height: 19px;
                            text: @tr("一个便捷的截图工具");
                            color: Palette.foreground;
                            font-size: SettingsTypography.body-font-size;
                            vertical-alignment: center;
                        }
                        Text {
                            height: 19px;
                            text: @tr("版本 {}", root.version-text);
                            color: Palette.alternate-foreground;
                            font-size: SettingsTypography.body-font-size;
                            vertical-alignment: center;
                        }
                    }
                    Rectangle { }
                }
                Rectangle { height: 1px; background: Palette.foreground.with-alpha(0.16); }
                HorizontalLayout {
                    height: 38px;
                    Text {
                        width: 72px;
                        text: @tr("构建信息");
                        color: Palette.alternate-foreground;
                        font-size: SettingsTypography.body-font-size;
                        vertical-alignment: top;
                    }
                    Text {
                        text: root.build-text;
                        color: Palette.foreground;
                        font-size: SettingsTypography.body-font-size;
                        wrap: word-wrap;
                        vertical-alignment: top;
                    }
                }
                Rectangle { height: 1px; background: Palette.foreground.with-alpha(0.16); }
                AboutLinkRow {
                    label: @tr("Git 项目");
                    link-text: "dripai/shitu.git";
                    target-url: "https://github.com/dripai/shitu.git";
                }
                AboutLinkRow {
                    label: @tr("问题反馈");
                    link-text: "https://github.com/dripai/shitu/issues";
                    target-url: "https://github.com/dripai/shitu/issues";
                }
                Text {
                    text: @tr("使用 Rust 与 Slint 构建 · © 2026");
                    color: Palette.alternate-foreground;
                    font-size: SettingsTypography.body-font-size;
                }
                Rectangle { }
                }
            }
            }

            HorizontalLayout {
                x: tabs.x;
                y: tabs.y;
                width: tabs.width;
                height: 32px;
                spacing: 0px;

                CenteredTabLabel { text: @tr("常规"); selected: root.current-tab == 0; }
                CenteredTabLabel { text: @tr("截图"); selected: root.current-tab == 1; }
                CenteredTabLabel { text: "OCR"; selected: root.current-tab == 2; }
                CenteredTabLabel { text: @tr("钉住"); selected: root.current-tab == 3; }
                CenteredTabLabel { text: @tr("快捷键"); selected: root.current-tab == 4; }
                CenteredTabLabel { text: @tr("关于"); selected: root.current-tab == 5; }
            }
        }

        Rectangle { height: 8px; }

        HorizontalLayout {
            height: 28px;
            Button {
                text: @tr("开始截图");
                clicked => { root.capture(); }
            }
            Rectangle { }
            Button {
                text: @tr("恢复默认");
                clicked => { root.restore-defaults(root.current-tab); }
            }
            Button {
                text: @tr("保存");
                clicked => { root.apply-settings(); }
            }
        }
    }
}
