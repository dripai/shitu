import { Palette } from "std-widgets.slint";

export component StatusBar inherits Rectangle {
    in property <string> status-text: "就绪";
    in property <int> status-level: 0;

    height: 22px;
    background: Palette.alternate-background;

    HorizontalLayout {
        padding-left: 7px;
        padding-right: 7px;
        spacing: 6px;

        dot-slot := Rectangle {
            width: 8px;

            Rectangle {
                y: (dot-slot.height - self.height) / 2;
                width: 8px;
                height: 8px;
                border-radius: 4px;
                background: root.status-level == 2
                    ? #cf222e
                    : root.status-level == 1 ? #238636 : Palette.alternate-foreground;
            }
        }
        Text {
            text: root.status-text;
            color: root.status-level == 2 ? #cf222e : Palette.foreground;
            font-size: 13px;
            vertical-alignment: center;
            overflow: elide;
        }
    }

    Tooltip { text: @markdown("\{root.status-text}"); }
}
