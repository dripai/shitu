import { Palette } from "std-widgets.slint";
import { CaptureToolbar } from "capture-toolbar.slint";

export struct AnnotationView {
    commands: string,
    stroke-color: color,
    stroke-width: float,
}

export component OverlayWindow inherits Window {
    title: "选择截图区域";
    background: transparent;
    no-frame: true;
    always-on-top: true;

    in property <int> capture-width: 1;
    in property <int> capture-height: 1;
    in property <image> selected-image;
    in property <[AnnotationView]> annotations;
    in property <string> selection-info;
    in property <int> output-mode: 0;
    in property <bool> ocr-available: false;
    in-out property <float> hover-left: 0;
    in-out property <float> hover-top: 0;
    in-out property <float> hover-right: 0;
    in-out property <float> hover-bottom: 0;

    in-out property <float> start-x: 0;
    in-out property <float> start-y: 0;
    in-out property <float> current-x: 0;
    in-out property <float> current-y: 0;
    in-out property <bool> selecting: false;
    in-out property <bool> completed: false;
    in-out property <int> active-tool: 0;
    in-out property <int> color-index: 0;
    in-out property <int> stroke-radius: 2;
    in-out property <float> drag-start-x: 0;
    in-out property <float> drag-start-y: 0;
    in-out property <float> drag-current-x: 0;
    in-out property <float> drag-current-y: 0;
    in-out property <float> press-x: 0;
    in-out property <float> press-y: 0;
    in-out property <bool> manual-drag: false;

    property <length> selection-left: Math.min(root.start-x, root.current-x) * 1px;
    property <length> selection-top: Math.min(root.start-y, root.current-y) * 1px;
    property <length> selection-width: Math.abs(root.current-x - root.start-x) * 1px;
    property <length> selection-height: Math.abs(root.current-y - root.start-y) * 1px;
    property <float> source-scale-x: Math.max(1, root.capture-width) / (root.width / 1px);
    property <float> source-scale-y: Math.max(1, root.capture-height) / (root.height / 1px);
    property <int> source-left: Math.max(
        0,
        Math.min(root.capture-width - 1, Math.round(root.selection-left / 1px * root.source-scale-x))
    );
    property <int> source-top: Math.max(
        0,
        Math.min(root.capture-height - 1, Math.round(root.selection-top / 1px * root.source-scale-y))
    );
    property <int> source-width: Math.min(
        root.capture-width - root.source-left,
        Math.max(1, Math.round(root.selection-width / 1px * root.source-scale-x))
    );
    property <int> source-height: Math.min(
        root.capture-height - root.source-top,
        Math.max(1, Math.round(root.selection-height / 1px * root.source-scale-y))
    );
    property <bool> hover-valid: root.hover-right > root.hover-left && root.hover-bottom > root.hover-top;
    property <length> hover-view-left: root.hover-left / root.source-scale-x * 1px;
    property <length> hover-view-top: root.hover-top / root.source-scale-y * 1px;
    property <length> hover-view-width: (root.hover-right - root.hover-left) / root.source-scale-x * 1px;
    property <length> hover-view-height: (root.hover-bottom - root.hover-top) / root.source-scale-y * 1px;
    property <bool> focus-visible: root.selecting || root.hover-valid;
    property <length> focus-left: root.selecting ? root.selection-left : root.hover-view-left;
    property <length> focus-top: root.selecting ? root.selection-top : root.hover-view-top;
    property <length> focus-width: root.selecting ? root.selection-width : root.hover-view-width;
    property <length> focus-height: root.selecting ? root.selection-height : root.hover-view-height;
    property <length> toolbar-x: Math.max(
        8px,
        Math.min(root.width - root.toolbar-width - 8px, root.selection-left)
    );
    property <length> toolbar-width: root.ocr-available ? 488px : 458px;
    property <length> toolbar-y: root.selection-top + root.selection-height + 52px <= root.height
        ? root.selection-top + root.selection-height + 12px
        : Math.max(8px, root.selection-top - 50px);

    callback probe-window(float, float);
    callback selected(float, float, float, float);
    callback begin-annotation(float, float, int);
    callback update-annotation(float, float);
    callback finish-annotation();
    callback select-color(int);
    callback select-width(int);
    callback undo();
    callback redo();
    callback complete-output();
    callback recognize-text();
    callback ocr-result(int, string);
    callback pin-selection();
    callback cancel-selection();

    function commit-selection() {
        let left = Math.max(0, Math.min(root.start-x, root.current-x));
        let top = Math.max(0, Math.min(root.start-y, root.current-y));
        let right = Math.min(root.width / 1px, Math.max(root.start-x, root.current-x));
        let bottom = Math.min(root.height / 1px, Math.max(root.start-y, root.current-y));
        root.start-x = left;
        root.start-y = top;
        root.current-x = right;
        root.current-y = bottom;
        root.selected(
            root.source-left,
            root.source-top,
            root.source-left + root.source-width,
            root.source-top + root.source-height
        );
    }

    FocusScope {
        key-pressed(event) => {
            if event.text == Key.Escape {
                root.cancel-selection();
                accept
            } else {
                reject
            }
        }
    }

    if !root.completed && !root.focus-visible: Rectangle {
        width: parent.width;
        height: parent.height;
        background: #00000088;
    }

    if !root.completed && root.focus-visible: Rectangle {
        width: parent.width;
        height: Math.max(0px, root.focus-top);
        background: #00000088;
    }
    if !root.completed && root.focus-visible: Rectangle {
        y: root.focus-top;
        width: Math.max(0px, root.focus-left);
        height: Math.max(0px, root.focus-height);
        background: #00000088;
    }
    if !root.completed && root.focus-visible: Rectangle {
        x: root.focus-left + root.focus-width;
        y: root.focus-top;
        width: Math.max(0px, parent.width - self.x);
        height: Math.max(0px, root.focus-height);
        background: #00000088;
    }
    if !root.completed && root.focus-visible: Rectangle {
        y: root.focus-top + root.focus-height;
        width: parent.width;
        height: Math.max(0px, parent.height - self.y);
        background: #00000088;
    }

    if !root.completed && root.hover-valid && !root.selecting: Rectangle {
        x: root.focus-left;
        y: root.focus-top;
        width: Math.max(1px, root.focus-width);
        height: Math.max(1px, root.focus-height);
        border-width: 2px;
        border-color: #54a5ff;
        background: transparent;
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        enabled: !root.completed;
        mouse-cursor: crosshair;

        moved => {
            let mouse-x = self.mouse-x / 1px;
            let mouse-y = self.mouse-y / 1px;
            if self.pressed {
                let moved-x = Math.abs(mouse-x - root.press-x);
                let moved-y = Math.abs(mouse-y - root.press-y);
                if !root.manual-drag && (moved-x >= 4 || moved-y >= 4) {
                    root.manual-drag = true;
                    root.selecting = true;
                    root.start-x = root.press-x;
                    root.start-y = root.press-y;
                }
                if root.manual-drag {
                    root.current-x = mouse-x;
                    root.current-y = mouse-y;
                }
            } else {
                root.probe-window(
                    mouse-x * root.source-scale-x,
                    mouse-y * root.source-scale-y
                );
            }
        }

        pointer-event(event) => {
            if event.kind == PointerEventKind.down {
                root.press-x = self.mouse-x / 1px;
                root.press-y = self.mouse-y / 1px;
                root.start-x = root.press-x;
                root.start-y = root.press-y;
                root.current-x = root.press-x;
                root.current-y = root.press-y;
                root.manual-drag = false;
                root.selecting = false;
            } else if event.kind == PointerEventKind.up {
                if root.manual-drag {
                    root.current-x = self.mouse-x / 1px;
                    root.current-y = self.mouse-y / 1px;
                    root.selecting = false;
                    root.manual-drag = false;
                } else if root.hover-valid {
                    root.start-x = root.hover-view-left / 1px;
                    root.start-y = root.hover-view-top / 1px;
                    root.current-x = (root.hover-view-left + root.hover-view-width) / 1px;
                    root.current-y = (root.hover-view-top + root.hover-view-height) / 1px;
                }
                if root.selection-width >= 3px && root.selection-height >= 3px {
                    root.completed = true;
                    root.commit-selection();
                }
            } else if event.kind == PointerEventKind.cancel {
                root.selecting = false;
                root.manual-drag = false;
            }
        }
    }

    if root.selecting || root.completed: Rectangle {
        x: root.selection-left;
        y: root.selection-top;
        width: Math.max(1px, root.selection-width);
        height: Math.max(1px, root.selection-height);
        border-width: 2px;
        border-color: #54a5ff;
        background: transparent;
        clip: true;

        if root.completed: Image {
            width: parent.width;
            height: parent.height;
            source: root.selected-image;
            image-fit: fill;
        }

        for annotation in root.annotations: Path {
            width: parent.width;
            height: parent.height;
            commands: annotation.commands;
            viewbox-width: root.selected-image.width;
            viewbox-height: root.selected-image.height;
            fit: fill;
            clip: true;
            fill: transparent;
            stroke: annotation.stroke-color;
            stroke-width: Math.max(
                1,
                annotation.stroke-width * parent.width / 1px / root.selected-image.width
            ) * 1px;
            stroke-line-cap: round;
        }

        if root.completed && root.active-tool > 0: TouchArea {
            width: parent.width;
            height: parent.height;
            mouse-cursor: crosshair;

            pointer-event(event) => {
                let image-x = self.mouse-x / self.width * root.selected-image.width;
                let image-y = self.mouse-y / self.height * root.selected-image.height;
                if event.kind == PointerEventKind.down {
                    root.begin-annotation(image-x, image-y, root.active-tool);
                } else if event.kind == PointerEventKind.move && self.pressed {
                    root.update-annotation(image-x, image-y);
                } else if event.kind == PointerEventKind.up {
                    root.update-annotation(image-x, image-y);
                    root.finish-annotation();
                } else if event.kind == PointerEventKind.cancel {
                    root.finish-annotation();
                }
            }
        }

        if root.completed && root.active-tool == 0: TouchArea {
            width: parent.width;
            height: parent.height;
            mouse-cursor: move;

            pointer-event(event) => {
                if event.kind == PointerEventKind.down {
                    root.drag-start-x = root.start-x;
                    root.drag-start-y = root.start-y;
                    root.drag-current-x = root.current-x;
                    root.drag-current-y = root.current-y;
                } else if event.kind == PointerEventKind.move && self.pressed {
                    let delta-x = (self.mouse-x - self.pressed-x) / 1px;
                    let delta-y = (self.mouse-y - self.pressed-y) / 1px;
                    let selected-width = root.drag-current-x - root.drag-start-x;
                    let selected-height = root.drag-current-y - root.drag-start-y;
                    let next-left = Math.max(
                        0,
                        Math.min(root.width / 1px - selected-width, root.drag-start-x + delta-x)
                    );
                    let next-top = Math.max(
                        0,
                        Math.min(root.height / 1px - selected-height, root.drag-start-y + delta-y)
                    );
                    root.start-x = next-left;
                    root.start-y = next-top;
                    root.current-x = next-left + selected-width;
                    root.current-y = next-top + selected-height;
                } else if event.kind == PointerEventKind.up {
                    root.commit-selection();
                }
            }
        }
    }

    if root.completed && root.active-tool == 0: TouchArea {
        x: root.selection-left - 7px;
        y: root.selection-top - 7px;
        width: 14px;
        height: 14px;
        mouse-cursor: nwse-resize;

        pointer-event(event) => {
            if event.kind == PointerEventKind.down {
                root.drag-start-x = root.start-x;
                root.drag-start-y = root.start-y;
            } else if event.kind == PointerEventKind.move && self.pressed {
                root.start-x = Math.max(0, Math.min(
                    root.current-x - 3,
                    root.drag-start-x + (self.mouse-x - self.pressed-x) / 1px
                ));
                root.start-y = Math.max(0, Math.min(
                    root.current-y - 3,
                    root.drag-start-y + (self.mouse-y - self.pressed-y) / 1px
                ));
            } else if event.kind == PointerEventKind.up {
                root.commit-selection();
            }
        }
    }

    if root.completed && root.active-tool == 0: TouchArea {
        x: root.selection-left + root.selection-width - 7px;
        y: root.selection-top - 7px;
        width: 14px;
        height: 14px;
        mouse-cursor: nesw-resize;

        pointer-event(event) => {
            if event.kind == PointerEventKind.down {
                root.drag-current-x = root.current-x;
                root.drag-start-y = root.start-y;
            } else if event.kind == PointerEventKind.move && self.pressed {
                root.current-x = Math.min(root.width / 1px, Math.max(
                    root.start-x + 3,
                    root.drag-current-x + (self.mouse-x - self.pressed-x) / 1px
                ));
                root.start-y = Math.max(0, Math.min(
                    root.current-y - 3,
                    root.drag-start-y + (self.mouse-y - self.pressed-y) / 1px
                ));
            } else if event.kind == PointerEventKind.up {
                root.commit-selection();
            }
        }
    }

    if root.completed && root.active-tool == 0: TouchArea {
        x: root.selection-left - 7px;
        y: root.selection-top + root.selection-height - 7px;
        width: 14px;
        height: 14px;
        mouse-cursor: nesw-resize;

        pointer-event(event) => {
            if event.kind == PointerEventKind.down {
                root.drag-start-x = root.start-x;
                root.drag-current-y = root.current-y;
            } else if event.kind == PointerEventKind.move && self.pressed {
                root.start-x = Math.max(0, Math.min(
                    root.current-x - 3,
                    root.drag-start-x + (self.mouse-x - self.pressed-x) / 1px
                ));
                root.current-y = Math.min(root.height / 1px, Math.max(
                    root.start-y + 3,
                    root.drag-current-y + (self.mouse-y - self.pressed-y) / 1px
                ));
            } else if event.kind == PointerEventKind.up {
                root.commit-selection();
            }
        }
    }

    if root.completed && root.active-tool == 0: TouchArea {
        x: root.selection-left + root.selection-width - 7px;
        y: root.selection-top + root.selection-height - 7px;
        width: 14px;
        height: 14px;
        mouse-cursor: nwse-resize;

        pointer-event(event) => {
            if event.kind == PointerEventKind.down {
                root.drag-current-x = root.current-x;
                root.drag-current-y = root.current-y;
            } else if event.kind == PointerEventKind.move && self.pressed {
                root.current-x = Math.min(root.width / 1px, Math.max(
                    root.start-x + 3,
                    root.drag-current-x + (self.mouse-x - self.pressed-x) / 1px
                ));
                root.current-y = Math.min(root.height / 1px, Math.max(
                    root.start-y + 3,
                    root.drag-current-y + (self.mouse-y - self.pressed-y) / 1px
                ));
            } else if event.kind == PointerEventKind.up {
                root.commit-selection();
            }
        }
    }

    if root.completed: Rectangle {
        x: root.selection-left;
        y: root.selection-top >= 28px ? root.selection-top - 26px : root.selection-top + 4px;
        width: 118px;
        height: 22px;
        border-radius: 4px;
        background: #1f2329e8;

        Text {
            text: root.selection-info;
            color: #ffffff;
            font-size: 11px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    if root.completed: CaptureToolbar {
        x: root.toolbar-x;
        y: root.toolbar-y;
        annotation-tools-visible: true;
        ocr-available: root.ocr-available;
        pin-action-visible: true;
        output-mode: root.output-mode;
        active-tool <=> root.active-tool;
        color-index <=> root.color-index;
        stroke-radius <=> root.stroke-radius;
        undo => { root.undo(); }
        redo => { root.redo(); }
        complete-output => { root.complete-output(); }
        recognize-text => { root.recognize-text(); }
        pin-action => { root.pin-selection(); }
        cancel-action => { root.cancel-selection(); }
        select-color(index) => { root.select-color(index); }
        select-width(width) => { root.select-width(width); }
    }
}
