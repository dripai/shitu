import { Palette } from "std-widgets.slint";

component MenuRow inherits Rectangle {
    in property <string> text;
    in property <bool> checked: false;
    in property <bool> submenu: false;
    callback activated();

    height: 25px;
    background: touch.has-hover ? Palette.selection-background : transparent;

    if root.checked: Image {
        x: 8px;
        y: 6px;
        width: 13px;
        height: 13px;
        source: @image-url("../src/icons/check.svg");
        image-fit: contain;
    }
    Text {
        x: 28px;
        width: parent.width - 48px;
        text: root.text;
        color: touch.has-hover ? Palette.selection-foreground : Palette.foreground;
        font-size: 12px;
        vertical-alignment: center;
    }
    Text {
        x: parent.width - 18px;
        width: 12px;
        text: root.submenu ? "›" : "";
        color: touch.has-hover ? Palette.selection-foreground : Palette.foreground;
        font-size: 15px;
        vertical-alignment: center;
    }
    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.activated(); }
    }
}

export component PinMenuWindow inherits Window {
    title: "钉住菜单";
    no-frame: true;
    always-on-top: true;
    width: 220px;
    height: root.menu-height * 1px;
    background: Palette.background;

    in-out property <int> menu-page: 0;
    in-out property <int> alpha-percent: 100;
    in-out property <bool> shadow-enabled: true;
    in-out property <bool> top-enabled: true;
    in-out property <int> scale-percent: 100;
    in-out property <bool> toolbar-visible: false;
    in property <string> original-size-text;
    in property <bool> has-source-file: false;
    property <float> menu-height: root.menu-page == 0
        ? (root.has-source-file ? 333 : 308)
        : root.menu-page == 1 ? 158
        : root.menu-page == 2 ? 259
        : root.menu-page == 3 ? 83
        : 133;

    callback close-menu();
    callback close-pin();
    callback set-toolbar(bool);
    callback copy-image();
    callback save-image();
    callback recognize-text();
    callback set-opacity(int);
    callback set-shadow(bool);
    callback set-top(bool);
    callback set-scale(int);
    callback fit-screen();
    callback replace-clipboard();
    callback replace-file();
    callback reveal-file();
    callback rotate-left();
    callback rotate-right();
    callback flip-horizontal();
    callback flip-vertical();

    FocusScope {
        key-pressed(event) => {
            if event.text == Key.Escape {
                root.close-menu();
                accept
            } else {
                reject
            }
        }
    }

    Rectangle {
        border-width: 1px;
        border-color: Palette.border;
        border-radius: 2px;
        background: Palette.background;

        if root.menu-page == 0: VerticalLayout {
            padding: 4px;
            spacing: 0px;
            MenuRow { text: "复制图像"; activated => { root.close-menu(); root.copy-image(); } }
            MenuRow { text: "图像另存为..."; activated => { root.close-menu(); root.save-image(); } }
            MenuRow { text: "OCR 识别"; activated => { root.close-menu(); root.recognize-text(); } }
            Rectangle { height: 1px; background: Palette.border; }
            MenuRow {
                text: "显示工具栏";
                checked: root.toolbar-visible;
                activated => {
                    root.toolbar-visible = !root.toolbar-visible;
                    root.close-menu();
                    root.set-toolbar(root.toolbar-visible);
                }
            }
            MenuRow {
                text: "窗口阴影";
                checked: root.shadow-enabled;
                activated => {
                    root.shadow-enabled = !root.shadow-enabled;
                    root.close-menu();
                    root.set-shadow(root.shadow-enabled);
                }
            }
            MenuRow {
                text: "始终置顶";
                checked: root.top-enabled;
                activated => {
                    root.top-enabled = !root.top-enabled;
                    root.close-menu();
                    root.set-top(root.top-enabled);
                }
            }
            MenuRow { text: "不透明度"; submenu: true; activated => { root.menu-page = 1; } }
            MenuRow { text: "缩放（\{root.scale-percent}%）"; submenu: true; activated => { root.menu-page = 2; } }
            Rectangle { height: 1px; background: Palette.border; }
            MenuRow { text: "图像处理"; submenu: true; activated => { root.menu-page = 4; } }
            MenuRow { text: "替换图像"; submenu: true; activated => { root.menu-page = 3; } }
            if root.has-source-file: MenuRow {
                text: "在文件夹中显示";
                activated => { root.close-menu(); root.reveal-file(); }
            }
            Rectangle { height: 1px; background: Palette.border; }
            MenuRow { text: "关闭"; activated => { root.close-menu(); root.close-pin(); } }
            Text {
                height: 22px;
                text: "原始尺寸：\{root.original-size-text}";
                color: Palette.alternate-foreground;
                font-size: 10px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        if root.menu-page == 1: VerticalLayout {
            padding: 4px;
            MenuRow { text: "‹ 返回"; activated => { root.menu-page = 0; } }
            MenuRow { text: "25%"; checked: root.alpha-percent == 25; activated => { root.close-menu(); root.set-opacity(25); } }
            MenuRow { text: "50%"; checked: root.alpha-percent == 50; activated => { root.close-menu(); root.set-opacity(50); } }
            MenuRow { text: "75%"; checked: root.alpha-percent == 75; activated => { root.close-menu(); root.set-opacity(75); } }
            MenuRow { text: "90%"; checked: root.alpha-percent == 90; activated => { root.close-menu(); root.set-opacity(90); } }
            MenuRow { text: "100%"; checked: root.alpha-percent == 100; activated => { root.close-menu(); root.set-opacity(100); } }
        }

        if root.menu-page == 2: VerticalLayout {
            padding: 4px;
            MenuRow { text: "‹ 返回"; activated => { root.menu-page = 0; } }
            MenuRow { text: "25%"; checked: root.scale-percent == 25; activated => { root.close-menu(); root.set-scale(25); } }
            MenuRow { text: "50%"; checked: root.scale-percent == 50; activated => { root.close-menu(); root.set-scale(50); } }
            MenuRow { text: "75%"; checked: root.scale-percent == 75; activated => { root.close-menu(); root.set-scale(75); } }
            MenuRow { text: "100%"; checked: root.scale-percent == 100; activated => { root.close-menu(); root.set-scale(100); } }
            MenuRow { text: "125%"; checked: root.scale-percent == 125; activated => { root.close-menu(); root.set-scale(125); } }
            MenuRow { text: "150%"; checked: root.scale-percent == 150; activated => { root.close-menu(); root.set-scale(150); } }
            MenuRow { text: "200%"; checked: root.scale-percent == 200; activated => { root.close-menu(); root.set-scale(200); } }
            Rectangle { height: 1px; background: Palette.border; }
            MenuRow { text: "适合屏幕"; activated => { root.close-menu(); root.fit-screen(); } }
            MenuRow { text: "恢复原始大小"; activated => { root.close-menu(); root.set-scale(100); } }
        }

        if root.menu-page == 3: VerticalLayout {
            padding: 4px;
            MenuRow { text: "‹ 返回"; activated => { root.menu-page = 0; } }
            MenuRow { text: "从剪贴板"; activated => { root.close-menu(); root.replace-clipboard(); } }
            MenuRow { text: "从文件..."; activated => { root.close-menu(); root.replace-file(); } }
        }

        if root.menu-page == 4: VerticalLayout {
            padding: 4px;
            MenuRow { text: "‹ 返回"; activated => { root.menu-page = 0; } }
            MenuRow { text: "向左旋转 90°"; activated => { root.close-menu(); root.rotate-left(); } }
            MenuRow { text: "向右旋转 90°"; activated => { root.close-menu(); root.rotate-right(); } }
            MenuRow { text: "水平翻转"; activated => { root.close-menu(); root.flip-horizontal(); } }
            MenuRow { text: "垂直翻转"; activated => { root.close-menu(); root.flip-vertical(); } }
        }
    }
}
