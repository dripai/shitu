import {
    Button, CheckBox, ComboBox, LineEdit, Palette, SpinBox, TabWidget
} from "std-widgets.slint";

global SettingsTypography {
    out property <length> title-font-size: 14px;
    out property <length> body-font-size: 13px;
}

component FieldLabel inherits Text {
    width: 92px;
    color: Palette.foreground;
    font-size: SettingsTypography.body-font-size;
    vertical-alignment: center;
}

component SectionTitle inherits Text {
    height: 24px;
    color: Palette.foreground;
    font-size: SettingsTypography.title-font-size;
    font-weight: 700;
    vertical-alignment: center;
}

component CenteredTabLabel inherits Rectangle {
    in property <string> text;
    in property <bool> selected;

    height: 32px;
    horizontal-stretch: 1;

    Text {
        text: root.text;
        color: root.selected ? Palette.foreground : Palette.alternate-foreground;
        font-size: SettingsTypography.body-font-size;
        font-weight: root.selected ? 700 : 400;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component AboutRow inherits HorizontalLayout {
    in property <string> label;
    in property <string> detail;

    height: 24px;
    spacing: 0px;

    Text {
        width: 72px;
        text: root.label;
        color: Palette.alternate-foreground;
        font-size: SettingsTypography.body-font-size;
        vertical-alignment: center;
    }
    Text {
        text: root.detail;
        color: Palette.foreground;
        font-size: SettingsTypography.body-font-size;
        vertical-alignment: center;
        overflow: elide;
    }
}

component PathActionButton inherits Rectangle {
    in property <string> text;
    callback activated();
    callback hover-changed(bool);

    width: 92px;
    height: 28px;
    border-width: 1px;
    border-color: Palette.foreground.with-alpha(0.24);
    border-radius: 3px;
    background: touch.pressed
        ? Palette.selection-background
        : touch.has-hover ? Palette.alternate-background : Palette.background;
    accessible-role: button;
    accessible-label: root.text;
    accessible-action-default => { root.activated(); }

    Text {
        text: root.text;
        color: Palette.foreground;
        font-size: SettingsTypography.body-font-size;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.activated(); }
        changed has-hover => { root.hover-changed(self.has-hover); }
    }
}

export component SettingsPanel inherits Rectangle {
    background: Palette.background;

    in-out property <int> current-tab: 0;
    in-out property <int> theme-mode: 0;
    in-out property <bool> launch-at-startup: false;
    in-out property <int> completion-action: 0;
    in-out property <int> image-format: 0;
    in-out property <int> jpeg-quality: 90;
    in-out property <string> save-directory;
    in-out property <string> filename-template;
    in-out property <bool> auto-save: false;
    in-out property <bool> save-notification: true;
    in-out property <int> pin-opacity: 100;
    in-out property <bool> pin-shadow: true;
    in-out property <bool> pin-always-on-top: true;
    in-out property <bool> pin-wheel-zoom: true;
    in-out property <int> pin-zoom-step: 15;
    in-out property <bool> pin-double-click-close: true;
    in-out property <string> hotkey-text;
    in property <int> hotkey-status: 0;
    in property <string> hotkey-status-tip;
    in property <string> version-text;
    in property <string> build-text;
    in property <string> log-path;
    in property <string> config-path;
    in property <bool> ocr-available: false;
    in property <string> ocr-status;

    callback apply-settings();
    callback capture();
    callback restore-defaults(int);
    callback choose-save-directory();
    callback open-save-directory();
    callback open-log-directory();
    callback open-config-directory();
    callback config-hint(bool);
    callback open-licenses();
    callback clear-hotkey();

    changed current-tab => { root.config-hint(false); }

    VerticalLayout {
        padding-left: 10px;
        padding-right: 10px;
        padding-bottom: 10px;
        padding-top: 0px;
        spacing: 0px;

        Rectangle {
            vertical-stretch: 1;

            tabs := TabWidget {
                width: 100%;
                height: 100%;
                current-index <=> root.current-tab;

            Tab {
                title: "";
                horizontal-stretch: 1;
                VerticalLayout {
                padding: 12px;
                spacing: 8px;
                SectionTitle { text: "应用"; }
                CheckBox {
                    text: "开机启动";
                    checked <=> root.launch-at-startup;
                }
                HorizontalLayout {
                    height: 26px;
                    FieldLabel { text: "外观模式"; }
                    ComboBox {
                        model: ["跟随系统", "浅色", "深色"];
                        current-index <=> root.theme-mode;
                    }
                }
                Rectangle { height: 1px; background: Palette.foreground.with-alpha(0.16); }
                SectionTitle { text: "文件与诊断"; }
                HorizontalLayout {
                    height: 28px;
                    spacing: 8px;
                    PathActionButton {
                        text: "打开日志";
                        activated => { root.open-log-directory(); }
                    }
                    Text {
                        text: root.log-path;
                        color: Palette.alternate-foreground;
                        font-size: SettingsTypography.body-font-size;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }
                HorizontalLayout {
                    height: 28px;
                    spacing: 8px;
                    PathActionButton {
                        text: "打开配置";
                        activated => { root.open-config-directory(); }
                        hover-changed(hovered) => { root.config-hint(hovered); }
                    }
                    Text {
                        text: root.config-path;
                        color: Palette.alternate-foreground;
                        font-size: SettingsTypography.body-font-size;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }
                Rectangle { }
                }
            }

            Tab {
                title: "";
                horizontal-stretch: 1;
                VerticalLayout {
                padding: 12px;
                spacing: 7px;
                VerticalLayout {
                    spacing: 7px;
                    SectionTitle { text: "输出"; }
                    HorizontalLayout {
                        height: 26px;
                        FieldLabel { text: "系统 OCR"; }
                        Text {
                            text: root.ocr-status;
                            color: root.ocr-available ? #16833d : #cf222e;
                            font-size: SettingsTypography.body-font-size;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                    }
                    HorizontalLayout {
                        height: 26px;
                        FieldLabel { text: "截图完成后"; }
                        ComboBox {
                            width: 240px;
                            model: ["复制到剪贴板", "保存到文件", "复制并保存"];
                            current-index <=> root.completion-action;
                        }
                        Rectangle { }
                    }
                    HorizontalLayout {
                        height: 26px;
                        FieldLabel { text: "图像格式"; }
                        ComboBox {
                            width: 112px;
                            model: ["PNG", "JPEG"];
                            current-index <=> root.image-format;
                        }
                        Text {
                            width: 68px;
                            text: "JPEG 质量";
                            color: Palette.foreground;
                            font-size: SettingsTypography.body-font-size;
                            vertical-alignment: center;
                        }
                        SpinBox {
                            width: 72px;
                            enabled: root.image-format == 1;
                            value <=> root.jpeg-quality;
                            minimum: 1;
                            maximum: 100;
                        }
                    }
                    HorizontalLayout {
                        height: 26px;
                        spacing: 6px;
                        FieldLabel { text: "保存目录"; }
                        LineEdit {
                            text <=> root.save-directory;
                        }
                        Button {
                            width: 58px;
                            text: "选择...";
                            clicked => { root.choose-save-directory(); }
                        }
                        Button {
                            width: 72px;
                            text: "打开目录";
                            clicked => { root.open-save-directory(); }
                        }
                    }
                    HorizontalLayout {
                        height: 26px;
                        FieldLabel { text: "文件名模板"; }
                        LineEdit {
                            text <=> root.filename-template;
                        }
                    }
                    CheckBox {
                        text: "自动保存（执行复制或钉住时同时保存）";
                        checked <=> root.auto-save;
                    }
                    CheckBox {
                        text: "显示保存结果";
                        checked <=> root.save-notification;
                    }
                    Rectangle { }
                }
                }
            }

            Tab {
                title: "";
                horizontal-stretch: 1;
                VerticalLayout {
                padding: 12px;
                spacing: 8px;
                SectionTitle { text: "新建钉住窗口"; }
                HorizontalLayout {
                    height: 26px;
                    FieldLabel { text: "默认不透明度"; }
                    SpinBox {
                        value <=> root.pin-opacity;
                        minimum: 25;
                        maximum: 100;
                    }
                    Text {
                        text: "%";
                        color: Palette.foreground;
                        font-size: SettingsTypography.body-font-size;
                        vertical-alignment: center;
                    }
                }
                CheckBox { text: "窗口阴影"; checked <=> root.pin-shadow; }
                CheckBox { text: "始终置顶"; checked <=> root.pin-always-on-top; }
                CheckBox { text: "启用滚轮缩放"; checked <=> root.pin-wheel-zoom; }
                HorizontalLayout {
                    height: 26px;
                    FieldLabel { text: "缩放步长"; }
                    SpinBox {
                        enabled: root.pin-wheel-zoom;
                        value <=> root.pin-zoom-step;
                        minimum: 5;
                        maximum: 100;
                    }
                    Text {
                        text: "%";
                        color: Palette.foreground;
                        font-size: SettingsTypography.body-font-size;
                        vertical-alignment: center;
                    }
                }
                CheckBox { text: "双击关闭"; checked <=> root.pin-double-click-close; }
                Rectangle { }
                }
            }

            Tab {
                title: "";
                horizontal-stretch: 1;
                VerticalLayout {
                padding: 12px;
                spacing: 8px;
                SectionTitle { text: "全局快捷键"; }
                HorizontalLayout {
                    height: 28px;
                    spacing: 6px;
                    FieldLabel { text: "区域截图"; }
                    LineEdit {
                        width: 190px;
                        text <=> root.hotkey-text;
                        placeholder-text: "例如 Ctrl+Alt+A；留空则关闭";
                    }
                    Button {
                        width: 52px;
                        text: "清除";
                        clicked => { root.clear-hotkey(); }
                    }
                    if root.hotkey-status > 0: Rectangle {
                        width: 22px;
                        height: 22px;
                        border-radius: 11px;
                        background: root.hotkey-status == 1 ? #238636 : #cf222e;
                        Text {
                            text: root.hotkey-status == 1 ? "√" : "!";
                            color: #ffffff;
                            font-size: 15px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        Tooltip { text: @markdown("\{root.hotkey-status-tip}"); }
                    }
                    Rectangle { }
                }
                if root.hotkey-status != 1: Text {
                    text: root.hotkey-status == 0
                        ? "未设置时不会注册任何全局快捷键。"
                        : root.hotkey-status-tip;
                    color: Palette.alternate-foreground;
                    font-size: SettingsTypography.body-font-size;
                }
                Rectangle { }
                }
            }

            Tab {
                title: "";
                horizontal-stretch: 1;
                VerticalLayout {
                padding: 12px;
                spacing: 6px;
                HorizontalLayout {
                    height: 42px;
                    spacing: 7px;
                    Image {
                        width: 32px;
                        height: 32px;
                        source: @image-url("icons/tray.svg");
                        image-fit: contain;
                    }
                    Text {
                        text: "截图工具";
                        color: Palette.foreground;
                        font-size: 16px;
                        font-weight: 700;
                        vertical-alignment: center;
                    }
                    Text {
                        text: root.version-text;
                        color: Palette.alternate-foreground;
                        font-size: SettingsTypography.body-font-size;
                        vertical-alignment: center;
                    }
                    Rectangle { }
                }
                Rectangle { height: 1px; background: Palette.foreground.with-alpha(0.16); }
                HorizontalLayout {
                    height: 38px;
                    Text {
                        width: 72px;
                        text: "构建信息";
                        color: Palette.alternate-foreground;
                        font-size: SettingsTypography.body-font-size;
                        vertical-alignment: top;
                    }
                    Text {
                        text: root.build-text;
                        color: Palette.foreground;
                        font-size: SettingsTypography.body-font-size;
                        wrap: word-wrap;
                        vertical-alignment: top;
                    }
                }
                Rectangle { height: 1px; background: Palette.foreground.with-alpha(0.16); }
                AboutRow { label: "官网"; detail: "尚未配置"; }
                AboutRow { label: "Git 项目"; detail: "本地仓库（尚未配置远程）"; }
                AboutRow { label: "问题反馈"; detail: "尚未配置"; }
                HorizontalLayout {
                    height: 28px;
                    Text {
                        width: 72px;
                        text: "开源许可";
                        color: Palette.alternate-foreground;
                        font-size: SettingsTypography.body-font-size;
                        vertical-alignment: center;
                    }
                    Button { text: "查看第三方许可"; clicked => { root.open-licenses(); } }
                    Rectangle { }
                }
                Text {
                    text: "使用 Rust 与 Slint 构建 · © 2026";
                    color: Palette.alternate-foreground;
                    font-size: SettingsTypography.body-font-size;
                }
                Rectangle { }
                }
            }
            }

            HorizontalLayout {
                x: tabs.x;
                y: tabs.y;
                width: tabs.width;
                height: 32px;
                spacing: 0px;

                CenteredTabLabel { text: "常规"; selected: root.current-tab == 0; }
                CenteredTabLabel { text: "截图"; selected: root.current-tab == 1; }
                CenteredTabLabel { text: "钉住"; selected: root.current-tab == 2; }
                CenteredTabLabel { text: "快捷键"; selected: root.current-tab == 3; }
                CenteredTabLabel { text: "关于"; selected: root.current-tab == 4; }
            }
        }

        Rectangle { height: 8px; }

        HorizontalLayout {
            height: 28px;
            Button {
                text: "开始截图";
                clicked => { root.capture(); }
            }
            Rectangle { }
            Button {
                text: "恢复默认";
                clicked => { root.restore-defaults(root.current-tab); }
            }
            Button {
                text: "保存";
                clicked => { root.apply-settings(); }
            }
        }
    }
}
