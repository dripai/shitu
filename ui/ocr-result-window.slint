import { Button, Palette, TextEdit } from "std-widgets.slint";

export component OcrResultWindow inherits Window {
    title: @tr("OCR 识别结果");
    icon: @image-url("icons/tray.svg");
    preferred-width: 520px;
    preferred-height: 360px;
    min-width: 380px;
    min-height: 260px;
    background: Palette.background;
    default-font-size: 12.07px;

    in-out property <string> result-text;
    in property <string> status-text: @tr("可选择文字，或复制全部内容。");

    callback copy-text();
    callback close-result();

    FocusScope {
        key-pressed(event) => {
            if event.text == Key.Escape {
                root.close-result();
                accept
            } else {
                reject
            }
        }
    }

    VerticalLayout {
        padding: 12px;
        spacing: 8px;

        Text {
            text: @tr("识别结果");
            color: Palette.foreground;
            font-size: 14px;
            font-weight: 700;
            vertical-alignment: center;
        }

        result-editor := TextEdit {
            text <=> root.result-text;
            read-only: true;
            wrap: word-wrap;
            font-size: 13px;
        }

        HorizontalLayout {
            height: 30px;
            spacing: 6px;

            Text {
                text: root.status-text;
                color: Palette.alternate-foreground;
                font-size: 13px;
                vertical-alignment: center;
                overflow: elide;
            }
            Rectangle { }
            Button {
                text: @tr("复制全部");
                clicked => { root.copy-text(); }
            }
            Button {
                text: @tr("关闭");
                clicked => { root.close-result(); }
            }
        }
    }
}
